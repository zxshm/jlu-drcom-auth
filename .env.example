# Copy this file to a private env file and fill in values on the target host.
# Do not commit real credentials or device identifiers.

DRCOM_WIFI_SSID=your-campus-wifi
DRCOM_WIFI_IFACE=wlan0
DRCOM_SERVER=10.0.0.1
DRCOM_USERNAME=your-student-id
DRCOM_PASSWORD=your-password
DRCOM_REGISTERED_MAC=001122334455

DRCOM_HOST_NAME=linux-host
DRCOM_HOST_OS=Linux
DRCOM_PRIMARY_DNS=10.10.10.10
DRCOM_DHCP_SERVER=0.0.0.0

DRCOM_CHECK_INTERVAL=30
DRCOM_WIFI_RETRY_INTERVAL=5
DRCOM_MAX_WIFI_RETRIES=20
DRCOM_KEEP_ALIVE_INTERVAL=10
DRCOM_SOCKET_TIMEOUT=10
DRCOM_MAX_UDP_RETRIES=3
DRCOM_ONLINE_CHECK_INTERVAL=10
DRCOM_ONLINE_CHECK_TIMEOUT=5
DRCOM_ONLINE_CHECK_FAILS=1
DRCOM_ONLINE_CHECK_URLS=http://connectivitycheck.platform.hicloud.com/generate_204,http://connectivitycheck.gstatic.com/generate_204
